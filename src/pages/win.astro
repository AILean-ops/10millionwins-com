---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Win | 10 Million AI Wins</title>
    <meta name="description" content="A real AI Win from the 10 Million AI Wins public wall." />
    <meta property="og:title" content="A real AI Win" />
    <meta property="og:description" content="See how everyday people are using AI for practical wins." />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="Primary navigation">
        <a href="/" class="brand" aria-label="10 Million AI Wins home">
          <span class="brand-mark">10M</span>
          <span>10 Million AI Wins</span>
        </a>
        <div class="nav-links">
          <a href="/#submit">Submit a Win</a>
          <a href="/#wall">Win Wall</a>
        </div>
        <a href="/#submit" class="button">Report Your Win</a>
      </nav>
    </header>
    <main>
      <section class="band band-navy" style="min-height: calc(100vh - 76px); display: grid; align-items: center;">
        <div class="container">
          <div class="section-head">
            <h2 id="headline">AI Win</h2>
            <p class="section-copy" id="subhead">Loading approved win...</p>
          </div>
          <article class="form-shell" id="winDetail" style="max-width: 820px;">
            <p class="win-quote">Loading...</p>
          </article>
          <div class="share-actions" style="margin-top: 20px;">
            <button class="button" id="copyLink">Copy Link</button>
            <a class="button button-light" href="/#wall">Browse More Wins</a>
          </div>
        </div>
      </section>
    </main>
    <script>
      const params = new URLSearchParams(window.location.search);
      const id = params.get('id');
      const detail = document.querySelector('#winDetail');
      const headline = document.querySelector('#headline');
      const subhead = document.querySelector('#subhead');
      const copyLink = document.querySelector('#copyLink');

      function escapeHtml(value) {
        return String(value || '').replace(/[&<>"']/g, (char) => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
        })[char]);
      }

      if (!id) {
        detail.innerHTML = '<p class="win-quote">This win link is missing an ID.</p>';
      } else {
        fetch(`/api/wins/${encodeURIComponent(id)}`)
          .then((res) => res.ok ? res.json() : Promise.reject())
          .then((data) => {
            const win = data.win;
            headline.textContent = `${win.firstName}'s AI Win`;
            subhead.textContent = `${win.location || 'Shared online'}${win.role ? ` - ${win.role}` : ''}`;
            detail.innerHTML = `
              <div class="win-meta">
                <span class="pill pill-yellow">${escapeHtml(String(win.category || '').replace(/-/g, ' '))}</span>
                ${win.featured ? '<span class="pill pill-yellow">Featured</span>' : ''}
              </div>
              <p class="win-quote">"${escapeHtml(win.quote)}"</p>
              <p class="raw">${escapeHtml(win.win)}</p>
              ${win.outcome ? `<p class="raw">${escapeHtml(win.outcome)}</p>` : ''}
            `;
          })
          .catch(() => {
            headline.textContent = 'Win Not Found';
            subhead.textContent = 'This win may still be pending review or may have been removed.';
            detail.innerHTML = '<p class="win-quote">Approved wins appear here after moderation.</p>';
          });
      }

      copyLink.addEventListener('click', async () => {
        await navigator.clipboard.writeText(window.location.href);
        copyLink.textContent = 'Copied';
        window.setTimeout(() => copyLink.textContent = 'Copy Link', 1200);
      });
    </script>
  </body>
</html>
